library(terra)
library(imageRy)
library(viridis)
library(ggplot2)

im.list()

#NDVI data
NDVI<-im.import("Sentinel2_NDVI_2020") #sono 4 layer
par(mfrow=c(2,2))
plot(NDVI[[1]], col=inferno(100)) 
plot(NDVI[[2]], col=inferno(100))
plot(NDVI[[3]], col=inferno(100))
plot(NDVI[[4]], col=inferno(100))

plot(NDVI) #in alternativa

#faccio un istogramma
hist(NDVI) 

#pacchetto ggirdges converte una tabelle (frequenze) in un ridgeline plot
install.packages("ggridges")
im.ridgeline(NDVI, scale=1, palette="inferno") 
#distribuzione frequenze (tanti piccoli istorgammi che vengono uniti da una funzione kernel)
